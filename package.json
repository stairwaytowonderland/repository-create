{
	"name": "repository-create",
	"version": "1.42.0",
	"description": "Dynamically create GitHub repositories with pre-defined settings and branch rulesets using Octokit.js",
	"type": "module",
	"private": true,
	"exports": {
		".": "./dist/index.js"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"build": "npm run bundle",
		"bundle": "npm run format:write && npm run package",
		"format:write": "npx prettier --write \"src/**/*.ts\" ./*.{json,mjs,ts,yaml}",
		"format:check": "npx prettier --check \"src/**/*.ts\" ./*.{json,mjs,ts,yaml}",
		"format": "npm run format:write",
		"lint:check": "npx eslint \"src/**/*.ts\"",
		"lint:fix": "npx eslint \"src/**/*.ts\" --fix",
		"lint": "npm run lint:fix",
		"package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
		"package:watch": "npm run package -- --watch",
		"typecheck": "npx tsc --noEmit",
		"test": "npm run typecheck && npm run lint:check && npm run format:check",
		"all": "npm run format && npm run lint && npm run package"
	},
	"keywords": [
		"github",
		"actions"
	],
	"license": "MIT",
	"dependencies": {
		"@actions/core": "^3.0.0",
		"octokit": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/eslintrc": "^3.3.3",
		"@eslint/js": "^10.0.1",
		"@rollup/plugin-commonjs": "^29.0.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/npm": "^13.1.5",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"conventional-changelog-conventionalcommits": "^8.0.0",
		"dotenv": "^17.4.2",
		"esbuild": "^0.28.0",
		"eslint": "^10.0.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"rollup": "^4.61.0",
		"semantic-release": "^25.0.3",
		"semantic-release-export-data": "^1.2.0",
		"tslib": "^2.8.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	}
}
