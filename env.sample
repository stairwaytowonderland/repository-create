# GitHub Authentication
# A Personal Access Token (PAT) with repo and admin:org scopes.
# Future state: replaced by GitHub App credentials (see src/github-client.js).
GITHUB_TOKEN=

# Target GitHub organization
GITHUB_ORG=

# Repository name to create (can also be passed via --name flag)
REPO_NAME=

# Optional: path to a JSON settings/rulesets override file (can also be passed via --repo-config flag)
# Use this instead of the flag when invoking via `npm start` to avoid npm flag parsing warnings.
# REPO_CONFIG=config/config.default.json
